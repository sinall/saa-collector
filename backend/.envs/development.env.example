# MFactor Backend Development Environment Configuration
# Note: This project uses pyenv for Python environment management
# The active environment is 'mfactor-env' (based on Python 3.12.3)
# Make sure pyenv is installed and configured before running the backend

# Database Configuration
DATABASE_NAME=mfactor
DATABASE_USER=root
DATABASE_PASSWORD=your_password_here
DATABASE_HOST=localhost
DATABASE_PORT=3306

# Application Configuration
# APP_ENV determines which settings file to load (development.py or production.py)
# See mfactor/settings/__init__.py for details
APP_ENV=development
APP_DEBUG=True
DOMAIN_NAME=localhost

# Security Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
